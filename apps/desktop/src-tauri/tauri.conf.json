{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Session Monitor",
  "version": "0.1.0",
  "identifier": "com.codex.sessionmonitor",
  "build": {
    "beforeDevCommand": "npm run dev:tauri:prepare",
    "beforeBuildCommand": "npm run build:tauri:prepare",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Codex Session Monitor",
        "width": 1320,
        "height": 860,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
