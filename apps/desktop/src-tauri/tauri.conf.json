{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Codex Session Monitor",
  "version": "0.1.0",
  "identifier": "com.codex.sessionmonitor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Codex Session Monitor",
        "width": 1320,
        "height": 860,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
